APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Portas expostas pelo Docker Compose (host:container)
DOCKER_APP_PORT=8080
DOCKER_DB_PORT=3307

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=root

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# LARAVEL-USP-THEME
# https://github.com/uspdev/laravel-usp-theme

# O laravel-usp-theme permite que seja criado links
# para outras aplicações da unidade
#USP_THEME_SISTEMAS_1='{"text":"Pessoas","url":"http://localhost/pessoas"}'
#USP_THEME_SISTEMAS_2='{"text":"LDAP","url":"http://localhost/ldap"}'

# Escolha o skin a ser utilizado
#USP_THEME_SKIN=uspdev

REPLICADO_HOST=
REPLICADO_PORT=
REPLICADO_DATABASE=
REPLICADO_USERNAME=
REPLICADO_PASSWORD=
REPLICADO_SYBASE=

UNIDADE=IME

# SENHAUNICA-SOCIALITE ######################################
# https://github.com/uspdev/senhaunica-socialite
SENHAUNICA_KEY=
SENHAUNICA_SECRET=
SENHAUNICA_CALLBACK_ID=

# URL do servidor oauth no ambiente de dev (default: no)
#SENHAUNICA_DEV="https://dev.uspdigital.usp.br/wsusuario/oauth"

# URL do servidor oauth para uso com senhaunica-faker
#SENHAUNICA_DEV="http://127.0.0.1:3141/wsusuario/oauth"

# Esses usuários terão privilégios especiais
#SENHAUNICA_ADMINS=11111,22222,33333
#SENHAUNICA_GERENTES=4444,5555,6666

# Se os logins forem limitados a usuários cadastrados (onlyLocalUsers=true),
# pode ser útil cadastrá-los aqui.
#SENHAUNICA_USERS=777,888

# Se true, os privilégios especiais serão revogados ao remover da lista (default: false)
#SENHAUNICA_DROP_PERMISSIONS=true

# Habilite para salvar o retorno em storage/app/debug/oauth/ (default: false)
#SENHAUNICA_DEBUG=true

# SENHAUNICA-SOCIALITE ######################################

# SALAS API CONFIGURATION ######################################
# Sistema moderno de reservas que substitui a escrita direta no banco Urano
# Configuração completa para integração com a API REST do sistema Salas

# URL base da API Salas (OBRIGATÓRIO em produção)
# Aponta para o servidor onde a API Salas está hospedada
# ⚠️  PRODUÇÃO: Deve apontar para https://salas.ime.usp.br
# 🔒 DESENVOLVIMENTO: Pode apontar para ambiente de teste
SALAS_API_URL=https://salas.ime.usp.br

# Credenciais para autenticação na API Salas (OBRIGATÓRIAS)
# Email e senha de usuário autorizado a criar reservas via API
# ⚠️  SEGURANÇA: Use credenciais dedicadas para o sistema, não pessoais
# 🔒 PRODUÇÃO: Configurar usuário específico com permissões limitadas
SALAS_API_EMAIL=
SALAS_API_PASSWORD=

# Controle principal da integração (CRÍTICO)
# true: Usa API Salas para todas as reservas
# false: Mantém sistema legado (modo de compatibilidade)
# ⚠️  MIGRAÇÃO: Ativar somente após testes completos em staging
SALAS_USE_API=false

# Estratégia de erro quando API Salas indisponível (DECISÃO ARQUITETURAL AC5)
# false: Erro explícito - informa usuário e falha operação (RECOMENDADO)
# true: Fallback silencioso para Urano (DEPRECIADO - removido em AC5)
# ✅ PRODUÇÃO: Deve ser false para clareza operacional e monitoramento
SALAS_FALLBACK_TO_URANO=false

# Controles de logging da integração Salas
# Essenciais para monitoramento e troubleshooting
# ⚠️  PRODUÇÃO: SALAS_ENABLE_LOGGING=true sempre ativo
SALAS_ENABLE_LOGGING=true

# Logs detalhados de requisições HTTP (DEBUG)
# true: Registra todas as requisições feitas à API (headers, payload)
# ⚠️  DESENVOLVIMENTO: Útil para debug, PRODUÇÃO: desligar por performance
SALAS_LOG_REQUESTS=false

# Logs detalhados de respostas HTTP (DEBUG)  
# true: Registra todas as respostas da API (status, headers, body)
# ⚠️  DESENVOLVIMENTO: Útil para debug, PRODUÇÃO: desligar por performance
SALAS_LOG_RESPONSES=false

# TIMEOUTS DA API SALAS (segundos) ######################################
# Configurações críticas para estabilidade da integração

# Timeout para estabelecer conexão TCP com servidor
# Valor baixo detecta problemas de rede rapidamente
# 🕐 PRODUÇÃO: 10s adequado, 5s para detecção mais rápida
SALAS_API_CONNECTION_TIMEOUT=10

# Timeout para receber resposta completa da API
# Inclui processamento da requisição no servidor Salas
# 🕐 PRODUÇÃO: 30s para operações complexas, 60s em horários de pico
SALAS_API_REQUEST_TIMEOUT=30

# CONFIGURAÇÃO DE RETRY ######################################
# Sistema de reenvio automático para lidar com falhas temporárias

# Número máximo de tentativas para cada requisição
# Inclui a tentativa inicial + retries
# 🔄 PRODUÇÃO: 3 tentativas equilibra resiliência com performance
SALAS_API_MAX_RETRIES=3

# Delay inicial entre tentativas (segundos)
# Evita sobrecarga imediata do servidor em caso de falhas
SALAS_API_RETRY_DELAY=1

# Delay máximo entre tentativas (segundos)
# Impede delays excessivos em backoff exponencial
# 🕐 RECOMENDADO: Não exceder 10s para manter UX responsiva
SALAS_API_MAX_RETRY_DELAY=8

# RATE LIMITING ######################################
# Proteção contra sobrecarga da API Salas

# Número máximo de requisições por minuto
# Previne rate limiting pelo servidor Salas
# 📊 PRODUÇÃO: 30 req/min seguro, ajustar conforme uso real
SALAS_API_RATE_LIMIT=30

# Rajadas permitidas acima do limite por minuto
# Permite picos de tráfego sem rejeição imediata
# ⚡ CONFIGURAÇÃO: 5 requisições de burst adequado
SALAS_API_BURST_LIMIT=5

# CACHE DE RESPOSTAS ######################################
# Otimização de performance e redução de carga na API

# Habilita cache de respostas da API
# true: Melhora performance e reduz carga
# false: Sempre consulta API (útil para debug)
# 🚀 PRODUÇÃO: true obrigatório para performance
SALAS_CACHE_ENABLED=true

# TTL do cache de salas (segundos)
# Dados de salas mudam raramente, cache longo adequado
# 🏢 RECOMENDADO: 3600s (1h), pode ser maior em produção estável
SALAS_CACHE_ROOMS_TTL=3600

# TTL do cache de finalidades (segundos)
# Dados muito estáveis, cache longo seguro
# 📋 RECOMENDADO: 86400s (24h), dados raramente mudam
SALAS_CACHE_FINALIDADES_TTL=86400

# TTL do cache do token de autenticação (segundos)
# Baseado na expiração do token JWT da API Salas
# 🔑 PRODUÇÃO: Deve ser menor que expiração real do token
SALAS_CACHE_TOKEN_TTL=3600

# CIRCUIT BREAKER ######################################
# Proteção contra cascata de falhas quando API indisponível

# Habilita circuit breaker para falhas da API
# true: Para requisições quando muitas falhas consecutivas
# false: Continua tentando independente de falhas
# 🛡️  PRODUÇÃO: true obrigatório para estabilidade
SALAS_CIRCUIT_BREAKER_ENABLED=true

# Número de falhas consecutivas para abrir circuit
# Falhas 4xx (erro cliente) não contam
# ⚠️  CONFIGURAÇÃO: 5 falhas equilibra sensibilidade com estabilidade  
SALAS_CIRCUIT_BREAKER_FAILURES=5

# Tempo que circuit fica aberto (segundos)
# Período que requisições são rejeitadas automaticamente
# 🕐 PRODUÇÃO: 300s (5min) permite recuperação sem espera excessiva
SALAS_CIRCUIT_BREAKER_TIMEOUT=300

# Tempo para testar se API voltou (segundos)
# Intervalo entre tentativas de reconexão
# ⚡ CONFIGURAÇÃO: 30s adequado para detecção rápida de recuperação
SALAS_CIRCUIT_BREAKER_RECOVERY=30

# TRATAMENTO DE ERROS ######################################
# Configurações para logging e notificação de problemas

# Registra todos os erros da API nos logs Laravel
# true: Essencial para troubleshooting e monitoramento
# false: Só para debug, nunca em produção
# 📝 PRODUÇÃO: true obrigatório para operações
SALAS_LOG_ERRORS=true

# Notificações ativas para falhas da API
# true: Envia alertas por email/Slack quando API falha
# false: Só registra nos logs
# 🔔 PRODUÇÃO: true recomendado para alertas críticos
SALAS_NOTIFY_FAILURES=false

# Canais de notificação para alertas (log, mail, slack)
# Define onde enviar notificações de falhas
# 📧 CONFIGURAÇÃO: Adicionar 'mail' para produção
SALAS_NOTIFICATION_CHANNELS=log

# Máximo de falhas consecutivas antes de alerta crítico
# Threshold para acionar notificações de emergência
# 🚨 OPERAÇÃO: 10 falhas indica problema sistêmico
SALAS_MAX_FAILURES=10
